  // Page-specific SEO settings
  page             String   @unique // e.g., "home", "about", "products", etc.
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  ogImage          String?
  
  updatedBy        String?   @db.ObjectId
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("seo_settings")
}

// ============================================
// BANNER CAROUSEL
// ============================================

model BannerImage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl     String
  altText      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  updatedBy    String?  @db.ObjectId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("banner_images")
}

// ============================================
// HUB MANAGEMENT
// ============================================

model Hub {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  address     String?
  city        String
  state       String
  zipCode     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  
  @@map("hubs")
}

// ============================================
// VENDOR ENQUIRY
// ============================================

model VendorEnquiry {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  companyName String
  gstNumber   String
  email       String
  phone       String
  website     String?
  status      String   @default("pending") // pending | approved | rejected
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("vendor_enquiries")
}

// ============================================
// CONTACT/WEBSITE ENQUIRIES
// ============================================

model ContactEnquiry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("new") // new | read | replied | closed
  repliedAt DateTime?
  closedAt  DateTime?
  notes     String?  // Admin notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_enquiries")
}

// ============================================
// SUPPORT SYSTEM
// ============================================

model SupportTicket {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  ticketId    String   @unique
  subject     String
  category    String
  priority    String   @default("medium") // low, medium, high, urgent
  description String
  status      String   @default("open")   // open, in_progress, resolved, closed
  
  attachments String[] @default([])
  
  creatorId   String   @db.ObjectId
  creatorType String   // "admin", "vendor", "user"
  creatorName String?
  creatorEmail String?
  
  messages    TicketMessage[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("support_tickets")
}

model TicketMessage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  ticketId    String   @db.ObjectId
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  message     String
  attachments String[] @default([])
  
  senderId    String   @db.ObjectId
  senderType  String   // "admin", "vendor", "user"
  senderName  String
  
  isRead      Boolean  @default(false)
  
  createdAt   DateTime @default(now())

  @@map("ticket_messages")
}

// ============================================
// REVIEWS
// ============================================

model Review {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String   @db.ObjectId
  product     Product  @relation("ProductReviews", fields: [productId], references: [id], onDelete: Cascade)
  orderId     String   @db.ObjectId
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rating      Int      @default(5)
  comment     String?
  images      String[] @default([])
  isApproved  Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, productId, orderId])
  @@map("reviews")
}

// ============================================
// QC CHECKER MANAGEMENT
// ============================================

model QCChecker {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  checkerId         String    @unique // Human readable checker ID (e.g., QC-001)
  email             String    @unique
  password          String    // Hashed password
  name              String
  phone             String
  
  // Address
  address           String?
  city              String?
  state             String?
  zipCode           String?
  country           String?   @default("India")
  
  // Personal
  dateOfBirth       DateTime?
  
  // Professional
  joiningDate       DateTime  @default(now())
  specialization    String?
  experience        Int?      @default(0) // Years of experience
  certifications    String?
  
  // Assigned Hub
  assignedHubId     String?   @db.ObjectId
  
  // Status & Activity
  status            QCCheckerStatus @default(ACTIVE)
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  
  // Stats
  assignedVendors   Int       @default(0)
  completedInspections Int    @default(0)
  
  // Relations
  vendorsList       Vendor[]  @relation("VendorQCChecker")
  productsList      Product[] @relation("ProductQCChecker")
  inspections       Inspection[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("qc_checkers")
}

enum QCCheckerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// ============================================
// BILLING & INVOICE SETTINGS
// ============================================

model InvoiceSettings {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  invoicePrefix           String   @default("INV")
  sequenceLength          Int      @default(4)
  currentSequence         Int      @default(1)
  financialYearStart      DateTime
  financialYearEnd        DateTime
  autoFinancialYear       Boolean  @default(true)
  // Month (1-12) and day of month when FY starts — used for auto rollover
  financialYearStartMonth Int      @default(4)   // 4 = April (Indian FY)
  financialYearStartDay   Int      @default(1)   // 1st of the month
  formatTemplate          String   @default("{PREFIX}-{FY}-{SEQ}")
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("invoice_settings")
}

// ============================================
// SETTLEMENTS
// ============================================

model Settlement {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  settlementNumber String   // e.g. SET-2024-0001
  vendorId         String   @db.ObjectId
  vendorName       String
  orderId          String   @db.ObjectId
  billingNumber    String   // e.g. same as order invoice number
  period           String   // e.g. "February 2024"
  amount           Float
  dueDate          DateTime
  status           String   @default("Pending") // Pending, Processing, Paid, Failed
  paymentDate      DateTime?
  transactionId    String?

  vendor           Vendor   @relation(fields: [vendorId], references: [id])
  order            Order    @relation(fields: [orderId], references: [id])
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("settlements")
}

// ============================================
// INSPECTION MANAGEMENT
// ============================================

model Inspection {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  
  // Relations
  vendorId          String    @db.ObjectId
  vendor            Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  checkerId         String    @db.ObjectId
  checker           QCChecker @relation(fields: [checkerId], references: [id], onDelete: Cascade)
  
  // Assignment Details
  poNumber          String
  clientName        String
  scheduledDate     String    // YYYY-MM-DD
  scheduledTime     String    // HH:MM AM/PM
  priority          String    // high, medium, low
  estimatedDuration String
  
  // Status & Timing
  status            InspectionStatus @default(SCHEDULED)
  startedAt         DateTime?
  completedAt       DateTime?
  
  // Inspection Items (JSON array of category/subcategory objects assigned)
  itemsToInspect    Json
  
  // Results
  result            InspectionResult?
  score             Float?
  notes             String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([vendorId, status])
  @@index([vendorId, status, result])
  @@index([checkerId, status])
  @@index([completedAt])
  @@map("inspections")
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InspectionResult {
  PASSED
  FAILED
}

// Generic atomic counter for sequential code generation (vendor, future entities).
// Single-document upserts on MongoDB are atomic, so concurrent registrations
// cannot collide on the same sequence value.
model Counter {
  id    String @id @map("_id") // e.g. "vendor-2026"
  value Int    @default(0)

  @@map("counters")
}

// FCM device tokens for push notifications (mobile + web)
model DeviceToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  role      String   // ADMIN, VENDOR, QC_CHECKER, USER
  token     String   @unique
  platform  String   // android, ios, web
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, role])
  @@map("device_tokens")
// ============================================
// ANALYTICS & TRACKING
// ============================================

model PageView {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  page        String   // Page path e.g. "/products", "/checkout"
  userId      String?  @db.ObjectId
  sessionId   String?
  referrer    String?
  device      String?  // mobile, tablet, desktop
  browser     String?
  duration    Int?     // Time spent in seconds
  createdAt   DateTime @default(now())

  @@index([page])
  @@index([createdAt])
  @@index([userId])
  @@map("page_views")
}

model ProductView {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productId   String   @db.ObjectId
  productName String?
  category    String?
  userId      String?  @db.ObjectId
  sessionId   String?
  source      String?  // "search", "category", "home", "direct"
  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
  @@index([category])
  @@map("product_views")
}
