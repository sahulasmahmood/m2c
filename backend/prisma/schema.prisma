  // Basic Company Information
  companyName    String
  companyLogo    String?
  companyEmail   String?
  companyPhone   String?
  companyWebsite String?

  // Legal & Tax Information
  gstNumber                  String?
  panNumber                  String?
  cinNumber                  String?
  businessRegistrationNumber String?
  taxId                      String?

  // Registered Address
