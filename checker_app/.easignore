# Sibling apps / services in the monorepo — `../` is required because
# .easignore patterns resolve relative to the file's own directory (same
# convention `mobile/.easignore` uses). Without the `../` these were silent
# no-ops and the EAS archive ended up containing siblings instead of
# checker_app/.
../backend/
../frontend/
../mobile/
../docs/
../.agents/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Dependencies — EAS installs fresh
node_modules/

# Native folders — EAS runs expo prebuild
android/
ios/

# Dev caches
.expo/
.expo-shared/
dist/
web-build/
.cache/
.next/

# Env files — use EAS environment variables
.env
.env.*
!.env.example

# Logs & binaries
*.log
*.mp4
*.mov
*.zip
*.apk
*.aab
*.ipa

# Work artifacts
COMMIT_MESSAGE.txt
WORK_REPORT.md
CHANGES_COMPLETED.md
MOBILE_UPDATES_TODO.md
